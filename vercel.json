{
  "version": 2,
  "crons": [
    {
      "path": "/api/scrape-website",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/agent",
      "destination": "/public/index.html"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
